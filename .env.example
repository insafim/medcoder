# LLM provider keys (only the one you use needs to be set)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Model selection — pinned, dated snapshots for reproducibility
MEDCODER_LLM_MODEL=openai/gpt-4o-2024-08-06
MEDCODER_VERIFIER_MODEL=anthropic/claude-3-5-sonnet-20241022

# Pipeline tuning
MEDCODER_RETRIEVAL_TOP_K=15
MEDCODER_TEMPERATURE=0.0
MEDCODER_EMBEDDER=sentence-transformers/all-MiniLM-L6-v2

# Toggles
MEDCODER_NO_VERIFY=0
MEDCODER_LOG_LEVEL=INFO
