# Copy to .env (auto-loaded at startup). The default config is cross-family
# (OpenAI coder + Anthropic auditor), so a live `make run` needs BOTH of the first
# two keys. Point every model at one provider (see overrides below) if you only
# have a single key.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Model selection — current generation, cost-optimised (verified 2026-06-26).
# extraction + coder share MEDCODER_LLM_MODEL unless individually overridden;
# the auditor uses a different model family by default (heterogeneous verifier).
MEDCODER_LLM_MODEL=openai/gpt-5.4-mini
MEDCODER_VERIFIER_MODEL=anthropic/claude-haiku-4-5-20251001

# Optional per-agent overrides (fall back to MEDCODER_LLM_MODEL when unset).
# e.g. shave cost by dropping extraction to the cheaper nano tier:
# MEDCODER_EXTRACTION_MODEL=openai/gpt-5.4-nano
# MEDCODER_CODER_MODEL=openai/gpt-5.4-mini

# Reasoning effort for OpenAI GPT-5 models (none|low|medium|high). GPT-5 are
# reasoning models that reject a custom temperature, so MEDCODER_TEMPERATURE
# only applies to providers that honour it (e.g. Claude Haiku/Sonnet).
MEDCODER_REASONING_EFFORT=low

# Pipeline tuning
MEDCODER_RETRIEVAL_TOP_K=15
MEDCODER_TEMPERATURE=0.0
MEDCODER_EMBEDDER=sentence-transformers/all-MiniLM-L6-v2

# Toggles
MEDCODER_NO_VERIFY=0
MEDCODER_LOG_LEVEL=INFO
